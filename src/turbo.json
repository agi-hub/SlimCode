{
	"$schema": "https://turbo.build/schema.json",
	"extends": ["//"],
	"tasks": {
		"bundle": {
			"dependsOn": ["^build", "@roo-code/vscode-webview#build"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"../webview-ui/src/**",
				"../webview-ui/index.html",
				"../webview-ui/vite.config.ts"
			],
			"outputs": ["dist/**"]
		},
		"vsix": {
			"dependsOn": ["bundle"],
			"inputs": ["dist/**"],
			"outputs": ["../bin/**"]
		},
		"watch:bundle": {
			"dependsOn": ["@roo-code/build#build", "@roo-code/types#build"],
			"cache": false
		}
	}
}
